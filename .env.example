# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
# Full PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/portfolio

# ─────────────────────────────────────────────
# API Server
# ─────────────────────────────────────────────
# Port the Express server listens on
PORT=3001

# Secret used to sign sessions (use a long random string)
SESSION_SECRET=replace-this-with-a-long-random-secret

# ─────────────────────────────────────────────
# Frontend (Vite)
# ─────────────────────────────────────────────
# Base URL of the API server — used by React Query hooks
# In development: point to your local Express server
# In production: point to your deployed API URL (e.g. https://your-api.railway.app)
VITE_API_BASE_URL=http://localhost:3001
